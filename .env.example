# ── Stillframe backend config ──────────────────────────────────────────
# Copy to .env and adjust. Never commit .env.

# App
STILLFRAME_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated allowed origins for the frontend (Vite dev default shown)
CORS_ORIGINS=http://localhost:5173,http://localhost:5180

# Profile: "public" ships EMPTY (defaults, no personal data, what you commit/release).
# "creator" loads personal data + identity overrides from instance/ (gitignored).
STILLFRAME_PROFILE=public

# Persistence (on your machine). Encryption (SQLCipher) comes in a later phase.
# Public default: empty gitignored data dir. The repo ships with NO database.
DB_PATH=./data/stillframe.db
# Creator example (gitignored, never committed):
# DB_PATH=./instance/personal/stillframe.db

# Editable Editor identity. Blank = packaged defaults (prompts/presence.md,
# prompts/boundaries.md). Creator points these at personal, gitignored files:
# PRESENCE_PATH=./instance/personal/presence.md
# BOUNDARIES_PATH=./instance/personal/boundaries.md
PRESENCE_PATH=
BOUNDARIES_PATH=

# ── AI provider ────────────────────────────────────────────────────────
# Active provider: ollama | openai_compat | anthropic
ACTIVE_PROVIDER=ollama

# Ollama (local, default). On Docker Desktop (Windows/Mac) the backend
# container reaches host-published Ollama via host.docker.internal.
# Running the backend directly on the host? use http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Leave blank to auto-detect the first available model from /api/tags
OLLAMA_MODEL=

# OpenAI-compatible (llama.cpp / LM Studio / OpenAI). Optional.
OPENAI_BASE_URL=http://host.docker.internal:8080/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic (Claude). Optional — cloud, opt-in only.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
